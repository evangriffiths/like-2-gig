like2gig.evangriffiths.org {
    # Cron endpoint bypasses basic auth (has its own Bearer token)
    @cron path /api/cron/*
    handle @cron {
        reverse_proxy localhost:3001
    }

    # Everything else requires basic auth
    handle {
        basicauth {
            # Password hash generated with: caddy hash-password --plaintext <password>
            admin {$SITE_PASSWORD_HASH}
        }

        root * /opt/like2gig/client/dist
        file_server

        handle /auth/* {
            reverse_proxy localhost:3001
        }

        handle /api/* {
            reverse_proxy localhost:3001
        }

        handle {
            try_files {path} /index.html
        }
    }
}
